#!/usr/bin/env bash
# Loads homelab secrets from 1Password via op CLI at shell entry.
# Requires: direnv, 1password-cli, an active op session.
#
# Per-service exports are commented out by default so `direnv allow` succeeds
# before any 1P items exist. Uncomment each line as the corresponding workload
# is migrated and its 1P item is created in the Homelab vault.

set -euo pipefail

if ! command -v op >/dev/null 2>&1; then
  echo ".envrc: 1Password CLI (op) not installed — secrets will not be loaded" >&2
  return 0
fi

# --- Platform secrets (needed from Phase 2 onward) ---

# Restic / Backblaze B2 (needed for Phase 3 backup system)
export B2_ACCOUNT_ID="$(op read 'op://Homelab/b2-restic/account-id')"
export B2_ACCOUNT_KEY="$(op read 'op://Homelab/b2-restic/account-key')"
export RESTIC_PASSWORD="$(op read 'op://Homelab/b2-restic/repo-password')"
export RESTIC_REPOSITORY="$(op read 'op://Homelab/b2-restic/repository')"

# Route53 credentials for cert-manager DNS-01 (needed for Task 2.5)
export ROUTE53_ACCESS_KEY_ID="$(op read 'op://Homelab/route53-cert-manager/access-key-id')"
export ROUTE53_SECRET_ACCESS_KEY="$(op read 'op://Homelab/route53-cert-manager/secret-access-key')"

# ACME contact email for Let's Encrypt (needed for Task 2.5)
export ACME_EMAIL="$(op read 'op://Homelab/acme/email')"

# Tailscale auth key for the siderolabs/tailscale extension (needed for Task 2.8)
# export TAILSCALE_AUTH_KEY="$(op read 'op://Homelab/tailscale/homelab-auth-key')"

# --- Per-service secrets (uncomment per workload as they migrate in Phase 4) ---

# export SONARR_API_KEY="$(op read 'op://Homelab/sonarr/api-key')"
# export RADARR_API_KEY="$(op read 'op://Homelab/radarr/api-key')"
# export SABNZBD_API_KEY="$(op read 'op://Homelab/sabnzbd/api-key')"
# export HYDRA2_API_KEY="$(op read 'op://Homelab/hydra2/api-key')"
# export EMBY_API_KEY="$(op read 'op://Homelab/emby/api-key')"
# export JOTTA_USERNAME="$(op read 'op://Homelab/jottacloud/username')"
# export JOTTA_PASSWORD="$(op read 'op://Homelab/jottacloud/password')"
